/*
 * =============================================================================
 * GCP PROFILE — Google Cloud Platform Execution
 * =============================================================================
 *
 * Runs the transcriptome pipeline on Google Cloud using Google Batch.
 * Each Nextflow task becomes a Google Batch job that provisions a VM,
 * runs the containerized process, and tears down the VM when done.
 *
 * Usage:
 *   nextflow run main.nf --srr_id SRR5437876 -profile gcp
 *
 * Prerequisites:
 *   1. Run scripts/setup_gcp.sh to create project, bucket, service account
 *   2. Run scripts/push_containers.sh to push images to Artifact Registry
 *   3. Set GOOGLE_APPLICATION_CREDENTIALS env var to the key file path
 *
 * Cost estimates (spot VMs, small dataset ~2M reads):
 *   - Full pipeline: ~$0.50 - $2.00
 *   - Trinity (n2-highmem-8): ~$0.15/hr spot
 *   - ProstT5 (g2-standard-4 + L4 GPU): ~$0.40/hr spot
 *   - All other steps: ~$0.02-0.05/hr spot each
 *
 * Author: Corey Howe — 5 Prime Sciences interview project
 * =============================================================================
 */


/*
 * GOOGLE BATCH EXECUTOR
 * ----------------------
 * google-batch is the modern Nextflow executor for GCP.  It replaces the
 * deprecated google-lifesciences API.
 *
 * How it works:
 *   1. Nextflow submits a Batch job for each task
 *   2. Batch provisions a VM with the requested resources
 *   3. The VM pulls the container image from Artifact Registry
 *   4. Nextflow stages input files from GCS to the VM
 *   5. The container runs the task script
 *   6. Outputs are copied back to GCS
 *   7. The VM is terminated and resources released
 *
 * This means you only pay for compute while tasks are actually running.
 */
executor {
    name = 'google-batch'
}


/*
 * GOOGLE CLOUD SETTINGS
 * ----------------------
 * Configure via environment variables or override here.
 *
 * Required env vars:
 *   GOOGLE_APPLICATION_CREDENTIALS — path to service account key JSON
 *   GCP_PROJECT_ID — your GCP project ID
 *   GCP_BUCKET — GCS bucket name for work directory
 */
google {
    project = params.gcp_project ?: System.getenv('GCP_PROJECT_ID') ?: 'seq2func'
    region  = params.gcp_region  ?: System.getenv('GCP_REGION')     ?: 'us-central1'

    batch {
        // Use spot/preemptible VMs for massive cost savings (60-91% cheaper).
        // Spot VMs CAN be reclaimed by GCP at any time, but Nextflow's
        // errorStrategy 'retry' handles this gracefully — the task is
        // automatically resubmitted on a new VM.
        spot = true

        // Allow up to 3 retries for spot VM preemption
        // (separate from the process-level maxRetries for real errors)
        maxSpotAttempts = 3
    }
}


/*
 * WORK DIRECTORY — must be a GCS bucket path
 * Nextflow stages all intermediate files here.  The lifecycle policy
 * set by setup_gcp.sh auto-deletes work files after 7 days.
 */
workDir = "gs://${params.gcp_bucket ?: System.getenv('GCP_BUCKET') ?: 'seq2func-nextflow'}/nextflow-work"


/*
 * DATABASE PATHS — override local defaults with GCS paths
 * Databases are downloaded once by scripts/setup_databases.sh
 * and stored in the GCS bucket for reuse across pipeline runs.
 */
params.cdd_db      = "gs://${params.gcp_bucket ?: System.getenv('GCP_BUCKET') ?: 'seq2func-nextflow'}/databases/cdd/Cdd"
params.foldseek_db = "gs://${params.gcp_bucket ?: System.getenv('GCP_BUCKET') ?: 'seq2func-nextflow'}/databases/foldseek/pdb"


/*
 * DOCKER — always enabled on cloud executors
 */
docker {
    enabled = true
}


/*
 * PROCESS-SPECIFIC RESOURCE CONFIGURATIONS
 * -----------------------------------------
 * Each bioinformatics tool has different resource requirements.
 * We assign appropriate GCP machine types to optimize cost vs. speed.
 *
 * Machine type reference:
 *   e2-small:       2 vCPU,   2 GB  — $0.007/hr spot (trivial tasks)
 *   e2-standard-2:  2 vCPU,   8 GB  — $0.014/hr spot (lightweight)
 *   e2-standard-4:  4 vCPU,  16 GB  — $0.027/hr spot (moderate)
 *   n2-highmem-8:   8 vCPU,  64 GB  — $0.15/hr  spot (memory-intensive)
 *   g2-standard-4:  4 vCPU,  16 GB + 1x L4 GPU — $0.40/hr spot (GPU inference)
 */
process {

    // ── Default resources ──────────────────────────────────────────────
    cpus   = 2
    memory = '8 GB'
    time   = '2h'
    disk   = '50 GB'

    // ── SRA Download: Downloads from EBI ENA via curl (no SRA toolkit needed)
    withName: 'SRA_DOWNLOAD' {
        container   = 'ubuntu:22.04'
        machineType = 'e2-standard-4'
        cpus        = 4
        memory      = '8 GB'
        time        = '3h'
        disk        = '100 GB'
    }

    // ── FastQC: Lightweight quality check ──────────────────────────────
    withName: 'FASTQC|FASTQC_TRIMMED' {
        container   = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
        machineType = 'e2-standard-2'
        cpus        = 2
        memory      = '8 GB'
        disk        = '20 GB'
    }

    // ── Trimmomatic: Moderate CPU ─────────────────────────────────────
    withName: 'TRIMMOMATIC' {
        container   = 'quay.io/biocontainers/trimmomatic:0.39--hdfd78af_2'
        machineType = 'e2-standard-2'
        cpus        = 2
        memory      = '4 GB'
        disk        = '50 GB'
    }

    // ── Trinity: MEMORY-INTENSIVE de novo assembler ───────────────────
    // Trinity is the most resource-hungry step.  n2-highmem machines
    // provide 8 GB/vCPU ratio (vs 4 GB/vCPU for standard).
    // Memory scales on retry: 32 GB → 64 GB → 64 GB (capped)
    withName: 'TRINITY' {
        container   = 'trinityrnaseq/trinityrnaseq:2.15.2'
        machineType = 'n2-highmem-8'
        cpus        = 8
        memory      = { Math.min(32 * task.attempt, 64).GB }
        time        = '6h'
        disk        = '100 GB'
    }

    // ── TransDecoder: Moderate compute for ORF prediction ─────────────
    withName: 'TRANSDECODER_LONGORFS|TRANSDECODER_PREDICT' {
        container   = 'trinityrnaseq/transdecoder:5.7.1'
        machineType = 'e2-standard-4'
        cpus        = 4
        memory      = '16 GB'
        disk        = '50 GB'
    }

    // ── CDD Search: CPU-bound BLAST ───────────────────────────────────
    withName: 'CDD_SEARCH' {
        container   = 'ncbi/blast:2.15.0'
        machineType = 'e2-standard-4'
        cpus        = 4
        memory      = '16 GB'
        time        = '2h'
        disk        = '50 GB'
    }

    // ── ProstT5: GPU-ACCELERATED deep learning inference ──────────────
    // g2-standard-4 comes with 1x NVIDIA L4 GPU (24 GB VRAM).
    // The L4 is optimized for inference workloads and is significantly
    // cheaper than A100 ($0.40/hr spot vs $3.50/hr spot).
    //
    // ProstT5 processes ~50 proteins/minute on L4 GPU vs ~5/minute on CPU.
    withName: 'PROSTT5_PREDICT' {
        container   = 'us-central1-docker.pkg.dev/seq2func/nf-transcriptome/prostt5:latest'
        // Use CPU machine until GPU quota is approved
        // Switch to g2-standard-4 (L4 GPU) once quota is granted
        machineType = 'n2-highmem-4'
        cpus        = 4
        memory      = '32 GB'   // Model is ~11 GB — needs ~24 GB to load on CPU
        time        = '2h'
        disk        = '100 GB'
        // GPU is included with g2-standard-4 machine type (1x L4)
        // No explicit accelerator directive needed — the machine type includes it
    }

    // ── FoldSeek: CPU structural search ───────────────────────────────
    withName: 'FOLDSEEK_SEARCH' {
        container   = 'ghcr.io/steineggerlab/foldseek:latest'
        machineType = 'e2-standard-4'
        cpus        = 4
        memory      = '8 GB'
        time        = '1h'
        disk        = '50 GB'
    }

    // ── Merge Results: Minimal Python script ──────────────────────────
    withName: 'MERGE_RESULTS' {
        container   = 'trinityrnaseq/transdecoder:5.7.1'
        machineType = 'e2-medium'
        cpus        = 1
        memory      = '4 GB'
        time        = '30m'
        disk        = '10 GB'
    }
}
