/*
 * =============================================================================
 * Nextflow Configuration — nf-transcriptome
 * =============================================================================
 *
 * Configuration for the de novo transcriptome assembly and annotation pipeline.
 * Defines execution profiles, resource defaults, container settings, and
 * reporting options.
 *
 * Profiles are selected with -profile:
 *   nextflow run main.nf --srr_id SRR5437876 -profile standard
 *   nextflow run main.nf -profile test
 *   nextflow run main.nf -profile gpu
 *
 * Author: Corey Howe
 * =============================================================================
 */


/*
 * ---------------------------------------------------------------------------
 * MANIFEST
 * ---------------------------------------------------------------------------
 * Pipeline metadata — shown by `nextflow info` and in execution reports.
 */
manifest {
    name            = 'nf-transcriptome'
    author          = 'Corey Howe'
    homePage        = 'https://github.com/coreyhowe/nf-transcriptome'
    description     = 'De novo transcriptome assembly and annotation pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}


/*
 * ---------------------------------------------------------------------------
 * GLOBAL PROCESS DEFAULTS
 * ---------------------------------------------------------------------------
 * Apply to ALL processes unless overridden by a profile or process-level
 * directives in the module files.
 *
 * errorStrategy 'retry' + maxRetries: If a process fails (e.g., OOM),
 * Nextflow automatically retries.  Combined with dynamic resources
 * (memory { X.GB * task.attempt }), each retry gets more resources.
 *
 * task.attempt is a built-in: 1 on first try, 2 on first retry, etc.
 */
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    // Dynamic resource allocation: scale up on retries
    cpus   = 2
    memory = { 4.GB * task.attempt }
    time   = { 1.hour * task.attempt }
}


/*
 * ---------------------------------------------------------------------------
 * EXECUTION PROFILES
 * ---------------------------------------------------------------------------
 * Profiles separate "what" (pipeline logic) from "where" (execution env).
 * The same main.nf runs locally, on a cluster, or with GPU support.
 */
profiles {

    /*
     * STANDARD PROFILE (default)
     * Local execution with Docker.  Suitable for a workstation or laptop.
     */
    standard {
        docker.enabled = true
        // docker.runOptions = '--platform linux/amd64'  // Uncomment for Apple Silicon
        // For running Nextflow in Docker (DinD): set this to the host path of the pipeline
        // docker.mountFlags = 'cached'

        process {
            cpus   = 2
            memory = '8 GB'

            // Container assignments per process
            withName: 'SRA_DOWNLOAD' {
                container = 'ncbi/sra-tools:3.1.1'
            }
            withName: 'FASTQC|FASTQC_TRIMMED' {
                container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
            }
            withName: 'TRIMMOMATIC' {
                container = 'quay.io/biocontainers/trimmomatic:0.39--hdfd78af_2'
            }
            withName: 'TRINITY' {
                container = 'trinityrnaseq/trinityrnaseq:2.15.2'
                memory = { Math.min(8 * task.attempt, 20).GB }
                cpus   = 4
            }
            withName: 'TRANSDECODER_LONGORFS|TRANSDECODER_PREDICT' {
                container = 'trinityrnaseq/transdecoder:5.7.1'
            }
            withName: 'CDD_SEARCH' {
                container = 'ncbi/blast:2.15.0'
                cpus   = 4
                memory = '8 GB'
            }
            withName: 'PROSTT5_PREDICT' {
                container = 'nf-transcriptome-prostt5:latest'
                memory = '16 GB'
            }
            withName: 'FOLDSEEK_SEARCH' {
                container = 'ghcr.io/steineggerlab/foldseek:latest'
                cpus   = 4
                memory = '8 GB'
            }
            withName: 'MERGE_RESULTS' {
                container = 'trinityrnaseq/transdecoder:5.7.1'
            }
        }
    }

    /*
     * TEST PROFILE
     * Quick test with a small SRA accession or local test data.
     * Skips ProstT5 and FoldSeek for speed (~5 min runtime).
     */
    test {
        docker.enabled = true
        docker.runOptions = '--platform linux/amd64'

        params {
            srr_id        = 'SRR5437876'    // Small Arabidopsis RNA-seq (~2M reads)
            max_proteins  = 20              // Cap at 20 proteins for fast demo
            skip_prostt5  = true            // Skip GPU-dependent step
            skip_foldseek = true            // Skip database-dependent step
            skip_cdd      = true            // Skip CDD (no database in test mode)
            outdir        = 'test_results'
        }

        process {
            cpus   = 2
            memory = '4 GB'

            withName: 'TRINITY' {
                memory = { 8.GB * task.attempt }
                cpus   = 2
            }
        }
    }

    /*
     * FULL PROFILE
     * Real data with more resources.  For production or larger datasets.
     */
    full {
        docker.enabled = true

        process {
            cpus   = 8
            memory = '32 GB'

            withName: 'TRINITY' {
                memory = { 32.GB * task.attempt }
                cpus   = 8
            }
            withName: 'PROSTT5_PREDICT' {
                memory = '32 GB'
            }
        }
    }

    /*
     * GPU PROFILE
     * Enables GPU support for ProstT5.  Requires NVIDIA Docker runtime.
     */
    gpu {
        docker.enabled    = true
        docker.runOptions = '--gpus all --platform linux/amd64'

        process {
            withLabel: 'process_gpu' {
                // Nextflow GPU configuration
                // accelerator: number of GPUs to request
                accelerator 1, type: 'nvidia-tesla-t4'
                memory = '16 GB'
            }
        }
    }

    /*
     * GCP PROFILE
     * Google Cloud Platform execution using Google Batch.
     * VMs are provisioned on demand, run the containerized task, then tear down.
     * Requires: scripts/setup_gcp.sh run first, then scripts/push_containers.sh
     */
    gcp {
        includeConfig 'conf/gcp.config'
    }
}


// ── GCP Parameters (used by gcp profile) ───────────────────────────────
params.gcp_project = null    // Override: --gcp_project my-project-id
params.gcp_bucket  = null    // Override: --gcp_bucket my-bucket
params.gcp_region  = null    // Override: --gcp_region us-central1


/*
 * ---------------------------------------------------------------------------
 * EXECUTION REPORTS & TRACING
 * ---------------------------------------------------------------------------
 * Nextflow generates detailed execution reports automatically:
 *   - trace:    TSV of every task (CPU, memory, wall time, exit code)
 *   - timeline: HTML Gantt chart showing task execution over time
 *   - report:   HTML report with resource utilisation charts
 *   - dag:      Pipeline DAG as a graphic
 */
trace {
    enabled   = true
    file      = "results/pipeline_trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem'
}

timeline {
    enabled   = true
    file      = "results/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "results/pipeline_execution_report.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "results/pipeline_dag.html"
    overwrite = true
}
