/*
 * =============================================================================
 * SECURE ENVIRONMENT (TRE) PROFILE
 * =============================================================================
 *
 * Simulates execution inside a Trusted Research Environment (TRE), such as:
 *   - UK Biobank Research Analysis Platform (RAP) on DNAnexus
 *   - NHS Digital Secure Data Environment
 *   - OHDSI / TriNetX secure enclaves
 *   - Genomics England Research Environment
 *
 * WHAT IS A TRE?
 * ==============
 * A Trusted Research Environment is a secure, isolated computing environment
 * where sensitive data (e.g., patient-level genetic data, health records) can
 * be analysed without the data ever leaving the environment.
 *
 * Key constraints of a real TRE:
 *   1. NO INTERNET ACCESS — containers cannot pull images or download packages
 *      at runtime.  All code and dependencies must be pre-loaded.
 *   2. DATA CANNOT LEAVE — outputs go through a disclosure review process
 *      before being released.  Summary statistics are typically OK; individual
 *      data never leaves.
 *   3. AUDIT TRAILS — every action is logged for governance and compliance.
 *   4. READ-ONLY INPUT — raw data is mounted read-only to prevent accidental
 *      modification.
 *   5. NO EXTERNAL SERVICES — no access to external APIs, databases, or
 *      cloud services.
 *   6. RESOURCE QUOTAS — compute and storage are allocated and monitored.
 *
 * This profile simulates these constraints for development and testing.
 * In a real TRE, the infrastructure team would provide the execution
 * environment, and the pipeline would be adapted to their specific platform.
 * =============================================================================
 */

/*
 * LOCAL EXECUTOR
 * TREs typically run on dedicated infrastructure, not cloud spot instances.
 * We use 'local' executor to simulate this — tasks run as local processes.
 */
executor {
    name   = 'local'
    cpus   = 4
    memory = '16 GB'
}

/*
 * DOCKER WITH NETWORK ISOLATION
 * ==============================
 * The critical security measure: --network none disables all network access
 * from within the container.  This prevents:
 *   - Downloading packages at runtime (pip install, conda install)
 *   - Exfiltrating data to external servers
 *   - Accessing external APIs
 *
 * In a real TRE, network isolation is enforced at the infrastructure level
 * (VPC rules, firewall).  We simulate it at the container level.
 */
docker {
    enabled    = true
    runOptions = '--network none --read-only --tmpfs /tmp:rw,noexec,nosuid,size=1g'
    /*
     * --network none     : No network access at all
     * --read-only        : Container filesystem is read-only (prevents tampering)
     * --tmpfs /tmp:...   : Writable /tmp for intermediate files, but:
     *   - noexec: cannot execute binaries from /tmp (security hardening)
     *   - nosuid: setuid bits are ignored
     *   - size=1g: limit temp storage to prevent filling the host disk
     */
}

process {
    container = 'nf-gwas-mr-pipeline:latest'
    cpus      = 1
    memory    = '4 GB'
}

/*
 * COMPREHENSIVE AUDIT LOGGING
 * ============================
 * TREs require detailed audit trails for governance.  Nextflow's built-in
 * tracing captures everything needed:
 *   - What ran, when, for how long
 *   - Resource usage (CPU, memory, disk)
 *   - Exit codes and error messages
 *   - Input/output file hashes
 */
trace {
    enabled   = true
    file      = "${params.outdir}/audit/execution_trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}

timeline {
    enabled   = true
    file      = "${params.outdir}/audit/execution_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/audit/execution_report.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/audit/pipeline_dag.html"
    overwrite = true
}

/*
 * STRICT OUTPUT MANAGEMENT
 * =========================
 * In a real TRE, outputs are written to a designated directory that is
 * subject to disclosure review.  We enforce this by setting publishDir
 * globally.
 *
 * The disclosure review process typically checks that:
 *   - No individual-level data is in the outputs
 *   - Summary statistics have sufficient cell counts (n >= 5)
 *   - No re-identification risk
 *   - Plots don't reveal individual data points
 */
params.outdir = 'results/secure_output'
