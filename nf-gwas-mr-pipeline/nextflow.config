/*
 * =============================================================================
 * Nextflow Configuration — nf-gwas-mr-pipeline
 * =============================================================================
 *
 * This file defines execution profiles, resource defaults, and reporting
 * settings.  Nextflow reads this automatically when the pipeline runs.
 *
 * Profiles are selected with -profile:
 *   nextflow run main.nf -profile local
 *   nextflow run main.nf -profile gcp
 *   nextflow run main.nf -profile secure_env
 * =============================================================================
 */


/*
 * ---------------------------------------------------------------------------
 * MANIFEST
 * ---------------------------------------------------------------------------
 * Pipeline metadata — shown by `nextflow info` and in execution reports.
 */
manifest {
    name            = 'nf-gwas-mr-pipeline'
    author          = 'Corey'
    homePage        = 'https://github.com/corey/nf-gwas-mr-pipeline'
    description     = 'GWAS Summary Statistics QC and Two-Sample Mendelian Randomization Pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}


/*
 * ---------------------------------------------------------------------------
 * GLOBAL PROCESS DEFAULTS
 * ---------------------------------------------------------------------------
 * These apply to ALL processes unless overridden by a profile or by
 * process-level directives in the module files.
 *
 * errorStrategy 'retry' + maxRetries:  if a process fails (e.g., OOM),
 * Nextflow automatically retries it.  Combined with dynamic resources
 * (memory { 4.GB * task.attempt }), each retry gets more memory.
 *
 * task.attempt is a built-in variable: 1 on the first try, 2 on the
 * first retry, etc.  This is how Nextflow handles transient failures
 * gracefully on cloud/HPC where resource contention is common.
 */
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    // Dynamic resource allocation: scale up on retries
    cpus   = 1
    memory = { 4.GB * task.attempt }
    time   = { 1.hour * task.attempt }
}


/*
 * ---------------------------------------------------------------------------
 * EXECUTION PROFILES
 * ---------------------------------------------------------------------------
 * Profiles separate the "what" (the pipeline logic) from the "where"
 * (the execution environment).  The same main.nf runs locally, on GCP,
 * or in a secure TRE without changes.
 */
profiles {

    /*
     * LOCAL PROFILE
     * Run on the developer's laptop/workstation with Docker.
     */
    local {
        includeConfig 'conf/local.config'
    }

    /*
     * GCP PROFILE
     * Google Cloud Platform execution using Google Batch.
     * Requires GCP credentials and a project configured.
     */
    gcp {
        includeConfig 'conf/gcp.config'
    }

    /*
     * SECURE ENVIRONMENT PROFILE
     * Simulates a Trusted Research Environment (TRE) like UK Biobank
     * Research Analysis Platform (RAP) on DNAnexus.
     */
    secure_env {
        includeConfig 'conf/secure_env.config'
    }
}


/*
 * ---------------------------------------------------------------------------
 * EXECUTION REPORTS & TRACING
 * ---------------------------------------------------------------------------
 * Nextflow can generate detailed execution reports automatically.
 * These are invaluable for debugging, optimisation, and auditing.
 *
 *   - trace:    TSV of every task (CPU, memory, wall time, exit code)
 *   - timeline: HTML Gantt chart showing task execution over time
 *   - report:   HTML report with resource utilisation charts
 *   - dag:      Pipeline DAG as a graphic (requires Graphviz for PNG/SVG)
 */
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
    // Fields recorded for each task
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem'
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_execution_report.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_dag.html"
    overwrite = true
}
