/*
 * =============================================================================
 * GCP PROFILE — Google Cloud Platform Execution
 * =============================================================================
 *
 * Runs the pipeline on Google Cloud using Google Batch (formerly
 * Google Life Sciences API).  This configuration is realistic but
 * requires a GCP project with Batch API enabled.
 *
 * Usage:  nextflow run main.nf -profile gcp
 *
 * Prerequisites:
 *   - GCP project with billing enabled
 *   - Google Batch API enabled
 *   - Service account with appropriate permissions
 *   - Container image pushed to Google Artifact Registry or Docker Hub
 *   - Google Cloud Storage bucket for work directory
 *
 * 5 Prime Sciences is based in Montreal, so we use the closest GCP
 * region: northamerica-northeast1 (Montreal data centre).
 * =============================================================================
 */

/*
 * GOOGLE BATCH EXECUTOR
 * ----------------------
 * google-batch is the modern replacement for google-lifesciences.
 * It provisions VMs on demand, runs the container, then tears them down.
 *
 * Each Nextflow task becomes a Google Batch job.  Nextflow handles:
 *   - VM provisioning
 *   - Data staging from/to GCS
 *   - Container execution
 *   - Log collection
 */
executor {
    name = 'google-batch'
}

/*
 * GOOGLE CLOUD SETTINGS
 * ----------------------
 * These configure the GCP project, region, and storage.
 */
google {
    project = 'my-gcp-project'       // Replace with your GCP project ID
    region  = 'northamerica-northeast1'  // Montreal — closest to 5 Prime Sciences

    batch {
        // Use spot/preemptible VMs for cost savings (up to 91% cheaper)
        // Spot VMs can be reclaimed by GCP, but Nextflow's retry mechanism
        // handles this gracefully — the task is simply resubmitted.
        spot = true
    }
}

/*
 * WORK DIRECTORY
 * ---------------
 * On GCP, the work directory MUST be a GCS bucket.  Nextflow stages
 * input files from GCS into the VM, runs the task, then copies outputs
 * back to GCS.
 */
workDir = 'gs://my-bucket/nextflow-work'

/*
 * DOCKER
 * ------
 * Containers are always enabled on cloud executors.  The image must be
 * accessible from the VMs (public Docker Hub or Artifact Registry).
 */
docker {
    enabled = true
}

process {
    // Container image from a registry (replace with your image)
    container = 'us-docker.pkg.dev/my-gcp-project/nextflow/nf-gwas-mr-pipeline:latest'

    // Machine type influences cost and performance
    // n2-standard-4: 4 vCPUs, 16 GB RAM — good balance for bioinformatics
    machineType = 'n2-standard-4'

    // Resource requests (Nextflow maps these to GCP machine types)
    cpus   = 2
    memory = '8 GB'
    time   = '2h'

    // Disk size for the VM's scratch space
    disk = '50 GB'
}
