# Cloudflare R2 Configuration (file storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=nf-transcriptome

# Cloudflare D1 Configuration (production database)
D1_DATABASE_ID=your_database_id
D1_API_TOKEN=your_api_token

# GCP Configuration (pipeline execution on cloud)
# Run scripts/setup_gcp.sh to generate these values
GCP_PROJECT_ID=your_gcp_project_id
GCP_BUCKET=your_gcp_bucket
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=../nf-transcriptome/gcp-service-account-key.json

# Local Development
# Set to 'true' to use mock data instead of D1
USE_MOCK_DATA=false

# Database path for local SQLite (used when D1 is not configured)
LOCAL_DB_PATH=./data/local.db

# Nextflow pipeline directory (relative to web app root)
PIPELINE_DIR=../nf-transcriptome
