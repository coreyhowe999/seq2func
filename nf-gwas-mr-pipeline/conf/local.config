/*
 * =============================================================================
 * LOCAL PROFILE — Development / Laptop Execution
 * =============================================================================
 *
 * Runs the pipeline on the local machine using Docker containers.
 * Suitable for development, testing, and small datasets.
 *
 * Usage:  nextflow run main.nf -profile local
 * =============================================================================
 */

/*
 * EXECUTOR
 * --------
 * 'local' means Nextflow runs processes as local OS processes.
 * It uses a thread pool to parallelise — the size is controlled by
 * cpus and memory limits below.
 */
executor {
    name   = 'local'
    cpus   = 4        // Max CPUs across all concurrent tasks
    memory = '8 GB'   // Max total memory across all concurrent tasks
}

/*
 * DOCKER
 * ------
 * When docker.enabled = true, every process runs inside the specified
 * container.  This ensures reproducibility: the same Python/library
 * versions are used regardless of what's installed on the host.
 *
 * The container image is built from containers/Dockerfile.
 */
docker {
    enabled    = true
    runOptions = '--platform linux/amd64'  // Ensure consistency on Apple Silicon
}

/*
 * PROCESS DEFAULTS (local overrides)
 */
process {
    container = 'nf-gwas-mr-pipeline:latest'
    cpus      = 1
    memory    = '2 GB'
}
