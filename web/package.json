{
  "name": "nf-transcriptome-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "npx @cloudflare/next-on-pages && npx wrangler pages deploy .vercel/output/static --project-name=seq2func",
    "deploy:preview": "npx @cloudflare/next-on-pages && npx wrangler pages deploy .vercel/output/static --project-name=seq2func --branch=preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "npx wrangler d1 migrations apply nf-transcriptome-db --local",
    "db:migrate:prod": "npx wrangler d1 execute nf-transcriptome-db --file=./migrations/0001_initial.sql",
    "db:studio": "drizzle-kit studio",
    "pages:dev": "npx @cloudflare/next-on-pages && npx wrangler pages dev .vercel/output/static --d1=DB --r2=R2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.525.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.30.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.21.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.83.0"
  }
}
